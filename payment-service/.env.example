# Sao chép file này thành .env và điền giá trị thực
# cp .env.example .env

# PayOS Credentials - Lấy từ https://my.payos.vn -> Cài đặt -> API Keys
PAYOS_CLIENT_ID=your-client-id-here
PAYOS_API_KEY=your-api-key-here
PAYOS_CHECKSUM_KEY=your-checksum-key-here

# Return URLs
PAYOS_RETURN_URL=https://stay.hotelrestaurant.net//payment/success
PAYOS_CANCEL_URL=https://stay.hotelrestaurant.net//payment/cancel
